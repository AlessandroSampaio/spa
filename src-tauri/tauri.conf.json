{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "spa",
  "version": "../package.json",
  "identifier": "com.ars.spa",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SPA - Analise de Produtos",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdCNEJDRTJGNDJGNDFEMUIKUldRYkhmUkNMODVMZTNqZVZJZTZucVdMV2hWYWxwenY4amVTMUx5ODBTeVVqOExxaGN2Z3VIZ1EK",
      "endpoints": [
        "https://github.com/AlessandroSampaio/spa/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "msi",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
